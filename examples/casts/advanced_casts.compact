import M1_Test8 prefix $M1_Test8;
import M2_Test8 prefix $M2_Test8;
import M3_Test8 prefix $M3_Test8;

export ledger fancy_enum: $M1_Test8TestEnum;
export ledger fancy_enum2: $M3_Test8TestEnum;
export ledger fancy_enum3: $M3_Test8TestEnum2;

// Test8: Enum to enum casting
export circuit test8(m1_enum: $M1_Test8TestEnum, m2_enum: $M1_Test8TestEnum): $M2_Test8TestEnum {
    fancy_enum = disclose(m1_enum) as $M2_Test8TestEnum;
    // fancy_enum2 = disclose(m2_enum) as $M3_Test8TestEnum2;
    fancy_enum2 = disclose(m2_enum) as $M3_Test8TestEnum;

    const fancy_enum3 = fancy_enum2 as $M2_Test8TestEnum as $M1_Test8TestEnum as $M3_Test8TestEnum;
    test8_result = ((fancy_enum3 as Field) + (fancy_enum3 as Uint<64>) * (fancy_enum3 as Field)) as Field;

    test8_result2 = fancy_enum3 as Uint<32> as Field;

    return fancy_enum;
}


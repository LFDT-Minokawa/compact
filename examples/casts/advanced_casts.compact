        a: Field,
        b: Boolean,
        c: Vector<4, Uint<8>>
    }

    export struct TestStruct2 {
        a: Field,
        b: Field,
        c: TestStruct,
        d: Vector<1, Field>
    }
}

module M2_Test7 {
    export struct TestStruct {
        a: Field,
        b: Boolean,
        c: Vector<4, Uint<8>>
    }

    export struct TestStruct2 {
        a: Field,
        b: Field,
        c: TestStruct,
        d: Vector<1, Field>
    }
}

module M3_Test7 {
    export struct TestStruct1 {
        a1: Field,
        b1: Boolean,
        c1: Vector<4, Uint<8>>
    }

    export struct TestStruct {
        a: Field,
        b: Boolean,
        c: Vector<4, Uint<8>>
    }

    export struct TestStruct2 {
        a: Field,
        b: Field,
        c: TestStruct,
        d: Vector<1, Field>
    }
}

import M1_Test7 prefix $M1_Test7;
import M2_Test7 prefix $M2_Test7;
import M3_Test7 prefix $M3_Test7;

export ledger fancy_struct: $M1_Test7TestStruct;
export ledger fancy_struct2: $M2_Test7TestStruct;
export ledger fancy_struct3: $M1_Test7TestStruct2;

// Test7: Struct to Struct casting
export circuit test7(m1_struct: $M1_Test7TestStruct, m2_struct: $M2_Test7TestStruct, m1_struct2: $M1_Test7TestStruct2): $M2_Test7TestStruct {
    fancy_struct = disclose(m1_struct) as $M2_Test7TestStruct;
    // fancy_struct2 = disclose(m2_struct) as $M3_Test7TestStruct1;
    fancy_struct2 = disclose(m2_struct) as $M3_Test7TestStruct;

    // const a = fancy_struct as $M3_Test7TestStruct as Field;

    fancy_struct3 = disclose(m1_struct2) as $M3_Test7TestStruct2;
    const p = fancy_struct3.c as $M1_Test7TestStruct;
    const g = fancy_struct3.c as $M2_Test7TestStruct;

    for(const i of [p as $M1_Test7TestStruct, g as $M2_Test7TestStruct]) {
      const z = i.a + i.a;
    }

    return fancy_struct;
}


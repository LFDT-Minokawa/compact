import CompactStandardLibrary;

export ledger round: Counter;

export circuit increment(): [] {
  round.increment(1);
}

// test1: return ledger value - vector
ledger val1: Vector<10, Uint<8>>;

export circuit test1(param1: Bytes<10>): Vector<10, Uint<8>> {
  val1 = disclose(param1) as Vector<10, Uint<8>>;
  return val1;
}

// test2: create for loop with bytes as vector
export circuit test2(param1: Bytes<10>): [] {
    for(const i of param1 as Vector<10, Uint<8>>) {

    }
}


// test3: witness as bytes -> vector
witness w3(param1: Bytes<1024>): Vector<1024, Uint<8>>;

export circuit test3(param1: Bytes<1024>): Vector<1024, Uint<8>> {
   return disclose(w3(param1));
}

// test4: witness as vector -> bytes
witness w4(param1: Vector<1024, Uint<8>>): Bytes<1024>;

export circuit test4(param1: Vector<1024, Uint<8>>): Bytes<1024> {
   return disclose(w4(param1));
}

// test5: ADT Types
export ledger map5: Map<Bytes<1024>, Vector<1024, Uint<8>>>;

export circuit test5(param1: Vector<1024, Uint<8>>): [] {
   map5.insert(disclose(param1 as Bytes<1024>), disclose(param1));
}

// test6: module circuit with conversions
module M6 <#n> {
  export circuit test6(param1: Bytes<n>): Vector<n, Uint<8>> {
    return param1 as Vector<n, Uint<8>>;
  }
}

import M6<1024> prefix circuits$;

export circuit test6(param1: Bytes<1024>): Vector<1024, Uint<8>> {
  return circuits$test6(param1);
}

// test7: nested modules with conversions
module A {
  module B {
    module C {
      export circuit test7(param1: Bytes<1024>): Vector<1024, Uint<8>> {
        return param1 as Vector<1024, Uint<8>>;
      }
    }
    import C prefix C$;

    export circuit test7(param1: Bytes<1024>): Vector<1024, Uint<8>> {
       return C$test7(param1);
    }
  }
  import B prefix B$;

  export circuit test7(param1: Bytes<1024>): Vector<1024, Uint<8>> {
    return B$test7(param1);
  }
}

import A prefix A$;

export circuit test7(param1: Bytes<1024>): Vector<1024, Uint<8>> {
  return A$test7(param1);
}

// test8: fold with conversions
export circuit test8(param1: Bytes<1024>) : Uint<8> {
  return fold((a: Uint<8>, x: Uint<8>): Uint<8> => a + x as Uint<8>, 0 as Uint<8>, param1 as Vector<1024, Uint<8>>);
}

// test9: fold with conversions and default
export circuit test9(): Uint<8> {
  return fold((a: Uint<8>, x: Uint<8>): Uint<8> => a + x as Uint<8>, 0 as Uint<8>, default<Vector<1024, Uint<8>>>);
}

// test10: map with conversions
export circuit test10(param1: Bytes<1024>): Vector<1024, Uint<8>> {
  return map((a: Uint<8>, n: Uint<8>) => a + n as Uint<8>, param1 as Vector<1024, Uint<8>>, param1 as Vector<1024, Uint<8>>);
}

// test11: map with conversions and access
export circuit test11(): Bytes<1024> {
  const p = map((a: Uint<8>, n: Uint<8>) => a + n as Uint<8>, default<Vector<1024, Uint<8>>>, default<Vector<1024, Uint<8>>>);
  const z = p as Bytes<1024>;

  const x = (z as Vector<1024, Uint<8>>)[0] + p[0];
  return p as Bytes<1024>;
}

// test12: conversions in circuit calls
export circuit test12a(param1: Vector<1024, Uint<8>>): Bytes<1024> {
  return param1 as Bytes<1024>;
}

export circuit test12b(param1: Bytes<1024>): Vector<1024, Uint<8>> {
  return param1 as Vector<1024, Uint<8>>;
}

export circuit test12c(param1: Bytes<1024>): [] {
  const f = test12a(test12b(param1));
}

// test13: tuple as vector -> bytes
export circuit test13(): Bytes<5> {
  return [1 as Uint<7>,2 as Uint<6>,3 as Uint<5>,4 as Uint<4>,5 as Uint<3>] as Bytes<5>;
}

// test14: short if with conversions
export circuit test14(param1: Uint<8>, param2: Vector<0, Uint<8>>) : Vector<0, Uint<8>> {
  return param1 == 0 ? param2 : default<Bytes<0>> as Vector<0, Uint<8>>;
}

// test15: struct in conversions
struct var15 {
  param1: Vector<1024, Uint<8>>
}

export circuit test15(param1: var15, param2: Bytes<1024>): Vector<2, Bytes<1024>> {
    const p = var15 { param1: param2 as Vector<1024, Uint<8>> };
    return [param1.param1 as Bytes<1024>, p.param1 as Bytes<1024>];
}

// test16: generics usage -> bytes
circuit test16<#N>(param1: Vector<N, Uint<8>>): Bytes<N> {
  return param1 as Bytes<N>;
}

export circuit test16a(): [] {
 const p = test16<1024>(default<Vector<1024, Uint<8>>>);
}

// test17: generics usage -> vector
circuit test17<#N>(param1: Bytes<N>): Vector<N, Uint<8>> {
  return param1 as Vector<N, Uint<8>>;
}

export circuit test17a(): [] {
  const p = test17<1024>(default<Bytes<1024>>);
}

// test18: call std lib method with conversions
export circuit test18(param1: Vector<8, Uint<8>>): Bytes<32> {
  return persistentHash<Vector<2, Bytes<8>>>([pad(8, 'boberto'), param1 as Bytes<8>]);
}

// test19: map with vectors
export ledger var19: Map<Field, Bytes<2>>;

export circuit test19(): Bytes<2> {
  var19.insert(1, default<Vector<2, Uint<8>>> as Bytes<2>);
  return var19.lookup(1);
}

// test20: different comparisons with conversions
export circuit test20(): Bytes<2> {
  if(default<Vector<2, Uint<8>>> == default<Bytes<2>> as Vector<2, Uint<8>>) {
    return default<Bytes<2>>;
  } else {
    const p = pad(2, "AA");
    const z = pad(2, 'aa');
    return assert(p == z, "Grog") == default<Vector<0, Uint<1>>> ? p : z;
  }
}

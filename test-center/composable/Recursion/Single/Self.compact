
export ledger self: Self;
export ledger b: Boolean;

contract Self {
  circuit foo(x: Field): Field;
}

constructor () {
  b = true;
}

export circuit set(self_param: Self): [] {
  self = disclose(self_param);
}

export circuit foo(x: Field): Field {
  if (b) {
    b = false;
    return disclose(self).foo(disclose(x));
  } else {
    return x + 1;
  }
}

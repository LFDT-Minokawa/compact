{
    "compilerOptions": {
        "allowJs": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "@test/compact-test": ["./compact-test.ts"]
        },
        "strict": true,
        "target": "esnext",
        "types": ["vitest/globals"]

// An Opaque value casts to the same Opaque type: the cast is accepted by the
// compiler for both Uint8Array and string opaque wrappers.
export circuit opaque_casts_to_opaque(): Opaque<'Uint8Array'> {
    const uint8array = default<Opaque<'Uint8Array'>> as Opaque<'Uint8Array'>;
    const str = default<Opaque<'string'>> as Opaque<'string'>;
    return uint8array;
}

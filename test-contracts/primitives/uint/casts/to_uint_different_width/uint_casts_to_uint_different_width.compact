import CompactStandardLibrary;

// A Uint value casts to a Uint of a different bit width: widening preserves the
// value, and narrowing is allowed when the value still fits.
export circuit uint_casts_to_uint_different_width(): Uint<64> {
    const widened = 1 as Uint<1> as Uint<2> as Uint<4> as Uint<8> as Uint<16> as Uint<32> as Uint<64>;
    assert(widened == 1, "Widening through every width should preserve the value");

    const roundTrip = (255 as Uint<8>) as Uint<16> as Uint<8>;
    assert(roundTrip == 255, "Round-trip through a wider type should preserve 255");

    const zero = default<Uint<248>> as Uint<8> as Uint<1>;
    assert(zero == 0, "Zero narrows to any width");

    return widened;
}

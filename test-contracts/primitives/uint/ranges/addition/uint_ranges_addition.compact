import CompactStandardLibrary;

// Uint<0..N> addition: the result fits in a range type whose upper bound
// is the sum of the operand upper bounds.
export circuit uint_ranges_addition(): Uint<0..20> {
    const a: Uint<0..10> = 3;
    const b: Uint<0..10> = 5;

    const sum: Uint<0..20> = a + b;
    assert(sum == 8, "3 + 5 should equal 8");

    return sum;
}

import CompactStandardLibrary;

// A Vector is implicitly accepted where a tuple of the same length and element
// type is expected, with no explicit cast.
export circuit vector_implicit_casts_to_tuple(): [Uint<8>, Uint<8>] {
    const v: Vector<2, Uint<8>> = [1, 2];

    return v;
}

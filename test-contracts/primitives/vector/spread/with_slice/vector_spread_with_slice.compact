import CompactStandardLibrary;

// Spread composes with slice: each slice result is expanded into the new vector.
export circuit vector_spread_with_slice(): Vector<4, Field> {
    const source: Vector<5, Field> = [10 as Field, 20 as Field, 30 as Field, 40 as Field, 50 as Field];

    const result: Vector<4, Field> = [...slice<2>(source, 0), ...slice<2>(source, 3)];
    assert(result[0] == 10 as Field, "First element should be 10");
    assert(result[3] == 50 as Field, "Last element should be 50");

    return result;
}

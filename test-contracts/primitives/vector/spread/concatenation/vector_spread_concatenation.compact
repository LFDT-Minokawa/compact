import CompactStandardLibrary;

// Spreading two vectors into one literal concatenates their elements in order.
export circuit vector_spread_concatenation(): Vector<4, Field> {
    const a: Vector<2, Field> = [1 as Field, 2 as Field];
    const b: Vector<2, Field> = [3 as Field, 4 as Field];

    const combined: Vector<4, Field> = [...a, ...b];
    assert(combined[0] == 1 as Field, "First element should come from a");
    assert(combined[2] == 3 as Field, "Third element should come from b");

    return combined;
}

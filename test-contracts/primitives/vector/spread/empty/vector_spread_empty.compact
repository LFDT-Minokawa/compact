import CompactStandardLibrary;

// Spreading an empty vector contributes no elements, so it is a no-op within a
// surrounding vector literal.
export circuit vector_spread_empty(): Vector<3, Field> {
    const empty: Vector<0, Field> = [...[]];

    const result: Vector<3, Field> = [1 as Field, ...empty, 2 as Field, 3 as Field];
    assert(result[0] == 1 as Field, "First element should be 1");
    assert(result[1] == 2 as Field, "Empty spread should not shift elements");
    assert(result[2] == 3 as Field, "Last element should be 3");

    return result;
}

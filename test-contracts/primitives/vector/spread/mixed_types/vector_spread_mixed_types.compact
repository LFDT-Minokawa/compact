import CompactStandardLibrary;

// A spread can feed a heterogeneous tuple type, preserving the declared element
// type (Boolean and differing Uint widths) at each position.
export circuit vector_spread_mixed_types(): [Boolean, Uint<16>, Uint<32>] {
    const result: [Boolean, Uint<16>, Uint<32>] = [true, ...[2 as Uint<16>], 3];
    assert(result[0] == true, "First element should be true");
    assert(result[1] == 2, "Spread Uint<16> element should be 2");
    assert(result[2] == 3, "Trailing element should be 3");

    return result;
}

import CompactStandardLibrary;

export ledger default_result: Vector<4, Field>;

// The default value of a Field vector has every element initialized to zero.
export circuit vector_default_semantics(): Vector<4, Field> {
    default_result = default<Vector<4, Field>>;

    assert(default_result[0] == 0, "First element should be zero");
    assert(default_result[3] == 0, "Last element should be zero");

    return default_result;
}

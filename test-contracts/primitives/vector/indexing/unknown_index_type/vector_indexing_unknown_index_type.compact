import CompactStandardLibrary;

// Iterating the empty untyped vector gives the loop variable type Unknown, which
// cannot be used as an index (an index must have an unsigned type).
export circuit vector_indexing_unknown_index_type(): [] {
    const vector: Vector<16, Uint<16>> = default<Vector<16, Uint<16>>>;

    for (const element of []) {
        const value = vector[element];
    }
}

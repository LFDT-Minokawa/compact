import CompactStandardLibrary;

// Destructuring a vector binds names to its leading elements; a shorter pattern
// ignores the trailing elements, and a full pattern binds every element.
export circuit vector_destructuring_basic(): [Field, Field] {
    const vector: Vector<4, Field> = [10, 20, 30, 40];

    const [first, second] = vector;
    assert(first == 10, "First destructured element should be 10");
    assert(second == 20, "Second destructured element should be 20");

    const [a, b, c, d] = vector;
    assert(a == 10, "Full destructuring: element 0 should be 10");
    assert(d == 40, "Full destructuring: element 3 should be 40");

    return [first, second];
}

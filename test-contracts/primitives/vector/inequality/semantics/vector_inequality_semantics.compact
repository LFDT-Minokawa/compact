import CompactStandardLibrary;

// Inequality is the structural negation of equality: vectors are unequal when
// any element differs, while identical vectors are never unequal.
export circuit vector_inequality_semantics(): Boolean {
    const a: Vector<3, Field> = [10, 20, 30];

    assert(a != [10, 20, 31], "Differing in one element makes vectors unequal");
    assert(a != [30, 20, 10], "Reordered elements make vectors unequal");
    assert(!(a != [10, 20, 30]), "Identical vectors are not unequal");

    return a != [0, 0, 0];
}

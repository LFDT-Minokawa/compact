import CompactStandardLibrary;

export ledger loop_result: Field;

// A for...of loop can iterate a vector produced by a spread expression, walking
// the expanded elements in order.
export circuit vector_loop_spread_iteration(): Field {
    const a: Vector<2, Field> = [1, 2];
    const b: Vector<3, Field> = [3, 4, 5];

    for (const v of [...a, ...b]) {
        loop_result = loop_result + v;
    }

    assert(loop_result == 15, "Sum over the spread iterable should be 15");

    return loop_result;
}

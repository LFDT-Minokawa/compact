import CompactStandardLibrary;

// A cast cannot change the element count: a six-element tuple does not fit a
// Vector of length four.
export circuit vector_casts_to_vector_length_mismatch(): Vector<4, Boolean> {
    return [true, false, true, false, true, false] as Vector<4, Boolean>;
}

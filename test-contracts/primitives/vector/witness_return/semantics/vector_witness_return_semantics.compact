import CompactStandardLibrary;

witness vector_witness(): Vector<4, Field>;

// A witness may return a vector; the returned vector slices and indexes like any
// other vector. Its values stay private (used only in constraints, not disclosed).
export circuit vector_witness_return_semantics(): [] {
    const w = vector_witness();

    const window = slice<2>(w, 1);
    assert(window[0] == 6, "Sliced witness element 0 should be 6");
    assert(window[1] == 7, "Sliced witness element 1 should be 7");
    assert(w[0] == 5, "Witness element 0 should be 5");
    assert(w[3] == 8, "Witness element 3 should be 8");
}

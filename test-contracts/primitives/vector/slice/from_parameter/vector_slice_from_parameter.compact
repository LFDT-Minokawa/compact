import CompactStandardLibrary;

// A vector received as a circuit parameter slices like any other vector; the
// single sliced element keeps its Field type.
export circuit vector_slice_from_parameter(vector: [Boolean, Boolean, Field]): [Field] {
    return slice<1>(vector, 2);
}

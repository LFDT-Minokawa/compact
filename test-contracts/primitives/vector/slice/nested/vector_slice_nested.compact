import CompactStandardLibrary;

// Slices compose: a slice may itself be sliced again. Each size and index must
// still reduce to a constant, including a long hexadecimal literal with leading
// zeros.
export circuit vector_slice_nested(): Vector<2, Field> {
    const vector: Vector<8, Field> = [10, 20, 30, 40, 50, 60, 70, 80];

    const a = slice<2>(slice<4>(slice<4>(vector, 0x0), 0b0), 0x00000000000000000000000000000000002);

    assert(a[0x0] == 30, "Nested slice element 0 should be 30");
    assert(a[0x1] == 40, "Nested slice element 1 should be 40");

    return [a[0x0] * a[0x1], a[0x1] * a[0x0]];
}

import CompactStandardLibrary;

// Slicing a heterogeneous tuple keeps the element type at each sliced position:
// here a Uint<8> and a Boolean drawn out of a four-element mixed-type tuple.
export circuit vector_slice_mixed_types(): [Field, Boolean] {
    const a = [5 as Uint<64>, 4 as Uint<8>, true, default<Bytes<8>>];

    const window = slice<2>(a, 1);
    assert(window[0] == 4, "Sliced element 0 should be 4");
    assert(window[1] == true, "Sliced element 1 should be true");

    return window;
}

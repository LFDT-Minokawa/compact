import CompactStandardLibrary;

export ledger default_result: Bytes<128>;

export circuit bytes_default_semantics(): Bytes<128> {
    default_result = default<Bytes<128>>;

    assert(default_result[0] == 0 as Uint<8>, "First byte should be zero");
    assert(default_result[127] == 0 as Uint<8>, "Last byte should be zero");

    return default_result;
}

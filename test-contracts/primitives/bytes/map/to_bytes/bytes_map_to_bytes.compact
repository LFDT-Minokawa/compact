import CompactStandardLibrary;

export ledger map_result: Vector<8, Bytes<1>>;

export circuit bytes_map_to_bytes(): Vector<8, Bytes<1>> {
    const fields = [0, 1, 2, 3, 4, 5, 6, 7];

    map_result = map((x: Field) => Bytes[x as Uint<8>], fields);

    assert(map_result[0][0] == 0 as Uint<8>, "First mapped field should be 0");
    assert(map_result[7][0] == 7 as Uint<8>, "Last mapped field should be 7");

    return map_result;
}

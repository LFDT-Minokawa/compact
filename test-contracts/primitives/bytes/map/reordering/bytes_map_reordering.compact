import CompactStandardLibrary;

export ledger map_result: Vector<3, Bytes<2>>;

export circuit bytes_map_reordering(): Vector<3, Bytes<2>> {
    const vec_bytes = [Bytes[1, 2], Bytes[3, 4], Bytes[5, 6]];

    map_result = map(
        (b: Bytes<2>) => Bytes[b[1] + 1 as Uint<8>, b[0] + 1 as Uint<8>],
        vec_bytes
    );

    assert(map_result[0][0] == 3 as Uint<8>, "First modified byte should be 3 (2+1)");
    assert(map_result[0][1] == 2 as Uint<8>, "Second modified byte should be 2 (1+1)");

    return map_result;
}

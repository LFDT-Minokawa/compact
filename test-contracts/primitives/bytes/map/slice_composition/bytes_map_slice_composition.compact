import CompactStandardLibrary;

export ledger map_result: Vector<3, Bytes<1>>;

export circuit bytes_map_slice_composition(): Vector<3, Bytes<1>> {
    const bytes = Bytes[10, 20, 30, 40, 50];

    map_result = map(
        (x: Uint<8>) => Bytes[(x * 2) as Uint<8>],
        slice<3>(bytes, 0)
    );

    assert(map_result[0][0] == 20 as Uint<8>, "First doubled byte should be 20 (10*2)");

    return map_result;
}

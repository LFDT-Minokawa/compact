import CompactStandardLibrary;

export ledger slice_result: Bytes<0>;

export circuit bytes_slice_empty(): Bytes<0> {
    const bytes = Bytes[1, 2, 3, 4, 5];

    slice_result = slice<0>(bytes, 5);

    assert(slice_result == Bytes[], "Empty slice should be empty");

    return slice_result;
}

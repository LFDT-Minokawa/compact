import CompactStandardLibrary;

export ledger slice_result: Bytes<1>;

export circuit bytes_slice_basic(): Bytes<1> {
    const bytes = Bytes[1, 2, 3, 4, 5];

    slice_result = slice<1>(bytes, 4);

    assert(slice_result[0] == 5 as Uint<8>, "Sliced last element should be 5");

    return slice_result;
}

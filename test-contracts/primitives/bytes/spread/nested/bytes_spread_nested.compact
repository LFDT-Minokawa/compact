import CompactStandardLibrary;

export ledger spread_result: Bytes<12>;

export circuit bytes_spread_nested(): Bytes<12> {
    const bytes3 = Bytes[1, 2, 3];
    const bytes6 = Bytes[...bytes3, ...bytes3];

    spread_result = Bytes[...bytes6, ...bytes6];

    assert(spread_result[0] == 1 as Uint<8>, "First element should be 1");
    assert(spread_result[3] == 1 as Uint<8>, "Fourth element should be 1 (repeated)");
    assert(spread_result[6] == 1 as Uint<8>, "Seventh element should be 1 (second repetition)");
    assert(spread_result[11] == 3 as Uint<8>, "Last element should be 3");

    return spread_result;
}

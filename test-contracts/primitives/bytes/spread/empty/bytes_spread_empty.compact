import CompactStandardLibrary;

export ledger spread_result: Bytes<0>;

export circuit bytes_spread_empty(): Bytes<0> {
    const empty1 = Bytes[];
    const empty2 = Bytes[];

    spread_result = Bytes[...empty1, ...empty2];

    assert(spread_result == Bytes[], "Spreading two empty bytes should yield empty bytes");

    return spread_result;
}

import CompactStandardLibrary;

export ledger spread_result: Bytes<10>;

export circuit bytes_spread_basic(): Bytes<10> {
    const bytes = Bytes[0x00, 0xFF, 0b11111111, 0o377, 128];

    spread_result = Bytes[...bytes, ...bytes];

    assert(spread_result[0] == 0 as Uint<8>, "First byte should be 0");
    assert(spread_result[1] == 255 as Uint<8>, "Second byte should be 255");
    assert(spread_result[5] == 0 as Uint<8>, "Sixth byte should be 0 (repeated)");
    assert(spread_result[9] == 128 as Uint<8>, "Last byte should be 128");

    return spread_result;
}

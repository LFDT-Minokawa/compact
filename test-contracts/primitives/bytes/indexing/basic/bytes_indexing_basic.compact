import CompactStandardLibrary;

export ledger indexing_result: [Uint<8>, Uint<8>, Uint<8>];

export circuit bytes_indexing_basic(): [Uint<8>, Uint<8>, Uint<8>] {
    const bytes = Bytes[10, 20, 30, 40, 50, 60, 70, 80];

    indexing_result = [
        bytes[0],
        bytes[4],
        bytes[7]
    ];

    assert(indexing_result[0] == 10 as Uint<8>, "First indexed byte should be 10");
    assert(indexing_result[1] == 50 as Uint<8>, "Middle indexed byte should be 50");
    assert(indexing_result[2] == 80 as Uint<8>, "Last indexed byte should be 80");

    return indexing_result;
}

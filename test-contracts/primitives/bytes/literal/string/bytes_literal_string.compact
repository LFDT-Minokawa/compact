import CompactStandardLibrary;

// A string literal denotes a Bytes value of its ASCII bytes. Single and double
// quotes are equivalent, and the characters are taken literally rather than
// interpreted (e.g. '0x00' is four characters, not the number zero).
export circuit bytes_literal_string(): Bytes<8> {
    const ascii: Bytes<8> = 'abcdefgh';
    assert(ascii[0] == 97, "First character 'a' should be byte 97");
    assert(ascii[7] == 104, "Last character 'h' should be byte 104");

    const literal: Bytes<4> = '0x00';
    assert(literal[0] == 48, "'0' should be byte 48");
    assert(literal[1] == 120, "'x' should be byte 120, not interpreted as hex");

    const doubleQuoted = "hi";
    assert(doubleQuoted[0] == 104, "Double-quoted 'h' should be byte 104");
    assert(doubleQuoted[1] == 105, "Double-quoted 'i' should be byte 105");

    return ascii;
}

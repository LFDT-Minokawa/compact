import CompactStandardLibrary;

// Escape sequences in a string literal denote their control-character bytes.
export circuit bytes_literal_escape_sequences(): Bytes<2> {
    const newline: Bytes<1> = "\n";
    const tab: Bytes<1> = "\t";
    const carriageReturn: Bytes<1> = "\r";
    const crlf: Bytes<2> = "\r\n";

    assert(newline[0] == 10, "Newline should be byte 10");
    assert(tab[0] == 9, "Tab should be byte 9");
    assert(carriageReturn[0] == 13, "Carriage return should be byte 13");
    assert(crlf[0] == 13, "CRLF first byte should be 13");
    assert(crlf[1] == 10, "CRLF second byte should be 10");

    return crlf;
}

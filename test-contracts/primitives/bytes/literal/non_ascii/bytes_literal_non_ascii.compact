import CompactStandardLibrary;

// A non-ASCII character is encoded as its UTF-8 bytes, so its byte length can
// exceed its character length: "\nÄ" is three bytes (newline + 0xC3 0x84).
export circuit bytes_literal_non_ascii(): Bytes<3> {
    const value: Bytes<3> = "\nÄ";

    assert(value[0] == 10, "Leading newline should be byte 10");
    assert(value[1] == 195, "A-umlaut first UTF-8 byte should be 0xC3 (195)");
    assert(value[2] == 132, "A-umlaut second UTF-8 byte should be 0x84 (132)");

    return value;
}

import CompactStandardLibrary;

witness bytes_witness(): Bytes<4>;

// A witness may return a Bytes value; the returned bytes index like any other
// Bytes. Its values stay private (used only in constraints, not disclosed).
export circuit bytes_witness_return_semantics(): [] {
    const w = bytes_witness();

    assert(w[0] == 10, "Witness byte 0 should be 10");
    assert(w[1] == 20, "Witness byte 1 should be 20");
    assert(w[3] == 40, "Witness byte 3 should be 40");
}

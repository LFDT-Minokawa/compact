import CompactStandardLibrary;

export ledger fold_result: Uint<8>;

export circuit bytes_fold_summation(): Uint<8> {
    const bytes = Bytes[1, 2, 3, 4, 5];

    fold_result = fold(
        (acc: Uint<8>, x: Uint<8>) => (acc + x) as Uint<8>,
        0 as Uint<8>,
        bytes
    );

    assert(fold_result == 15 as Uint<8>, "Sum should be 15 (1+2+3+4+5)");

    return fold_result;
}

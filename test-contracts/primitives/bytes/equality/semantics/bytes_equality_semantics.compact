import CompactStandardLibrary;

// Non-empty Bytes compare structurally, and a Bytes equals a matching string
// literal of the same contents.
export circuit bytes_equality_semantics(): Boolean {
    const a: Bytes<3> = "bob";
    const b: Bytes<3> = "bob";
    const c: Bytes<3> = "nob";

    assert(a == b, "Identical bytes should be equal");
    assert(a == "bob", "Bytes should equal a matching string literal");
    assert((a == c) == false, "Bytes differing in one byte should be unequal");

    return a == b;
}

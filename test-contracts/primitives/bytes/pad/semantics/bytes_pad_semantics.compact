import CompactStandardLibrary;

// pad(n, bytes) right-pads `bytes` with zero bytes up to length n.
export circuit bytes_pad_semantics(): Bytes<4> {
    const grown = pad(4, "ab");
    assert(grown[0] == 97, "First byte should be 'a' (97)");
    assert(grown[1] == 98, "Second byte should be 'b' (98)");
    assert(grown[2] == 0, "Third byte should be zero padding");
    assert(grown[3] == 0, "Fourth byte should be zero padding");

    const padded_empty = pad(2, "");
    assert(padded_empty[0] == 0, "Padded empty byte 0 should be zero");
    assert(padded_empty[1] == 0, "Padded empty byte 1 should be zero");

    return grown;
}

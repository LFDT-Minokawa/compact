import CompactStandardLibrary;

// Casting a default-initialized Bytes to a Vector yields an all-zero vector.
export circuit bytes_casts_to_vector_default(): Vector<4, Uint<8>> {
    const zeros = default<Bytes<4>> as Vector<4, Uint<8>>;
    assert(zeros[0] == 0, "Default Bytes should cast to a zero vector");
    assert(zeros[3] == 0, "Default Bytes should cast to a zero vector");

    return zeros;
}

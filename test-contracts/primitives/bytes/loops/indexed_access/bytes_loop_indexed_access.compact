import CompactStandardLibrary;

export ledger loop_result: Field;

export circuit bytes_loop_indexed_access(): Field {
    const b1 = Bytes[1, 2, 3, 4];
    const b2 = Bytes[5, 6, 7, 8];

    const bytes = Bytes[...b1, ...b2];
    const bytes2 = Bytes[...b2, ...b1, 1];

    for (const b of bytes) {
        loop_result = loop_result + bytes2[b];
    }

    assert(loop_result == 32 as Field, "Indexed accumulation should equal 32");

    return loop_result;
}

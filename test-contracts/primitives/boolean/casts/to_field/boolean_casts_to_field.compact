import CompactStandardLibrary;

// A Boolean value casts to Field: true becomes 1 and false becomes 0.
export circuit boolean_casts_to_field(): Field {
    const t = true as Field;
    const f = false as Field;
    assert(t == 1, "true should cast to 1");
    assert(f == 0, "false should cast to 0");
    return t;
}

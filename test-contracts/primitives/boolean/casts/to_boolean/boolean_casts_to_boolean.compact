import CompactStandardLibrary;

// A Boolean value casts to Boolean: the cast is a no-op that preserves literal
// values, comparison results, and values returned from a circuit call.
export circuit boolean_casts_to_boolean(): Boolean {
    const t = true as Boolean;
    const f = false as Boolean;
    assert(t, "true should cast to true");
    assert(!f, "false should cast to false");

    const from_expr = (1 as Uint<8> > 0 as Uint<8>) as Boolean;
    assert(from_expr, "comparison result should cast correctly");

    return t;
}
